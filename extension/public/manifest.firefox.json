{
  "manifest_version": 3,
  "name": "InterceptKit",
  "version": "0.1.0",
  "description": "Capture requests and manage local proxy rewrite rules.",
  "permissions": [
    "storage",
    "proxy"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://127.0.0.1/*",
    "https://localhost/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "devtools_page": "devtools.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "interceptkit@local.dev"
    }
  }
}
